{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1160px",
			"wideSize": "1160px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"color": {
			"custom": true,
			"customGradient": true,
			"defaultPalette": true,
			"defaultGradients": true
		},
		"dimensions": {
			"aspectRatio": true,
			"minHeight": true
		},
		"spacing": {
			"blockGap": true,
			"margin": true,
			"padding": true,
			"units": [ "px", "em", "rem", "vh", "vw", "%" ]
		},
		"typography": {
			"lineHeight": true
		},
		"blocks": {
			"core/columns": {
				"spacing": {
					"blockGap": true,
					"margin": true,
					"padding": true
				}
			},
			"core/column": {
				"spacing": {
					"margin": true,
					"padding": true
				}
			},
			"core/image": {
				"dimensions": {
					"aspectRatio": true
				},
				"spacing": {
					"margin": true,
					"padding": true
				}
			}
		}
	}
}
