{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "procoders/hero-limited-section",
	"version": "1.0.0",
	"title": "Hero Limited Section",
	"category": "design",
	"icon": "cover-image",
	"description": "Hero section with limited inner blocks and editable media panels.",
	"textdomain": "procoders",
	"attributes": {
		"leftBackgroundImageId": {
			"type": "number",
			"default": 0
		},
		"leftBackgroundImageUrl": {
			"type": "string",
			"default": ""
		},
		"rightImageId": {
			"type": "number",
			"default": 0
		},
		"rightImageUrl": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"html": false,
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		},
		"dimensions": {
			"minHeight": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"editorScript": "file:./index.js",
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css"
}
